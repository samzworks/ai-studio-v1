{
  "name": "takuween",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev:client": "vite --host 0.0.0.0 --port 5173",
    "dev:server": "tsx -r dotenv/config server/index.ts",
    "dev": "bash -lc 'npm run dev:client & npm run dev:server'",
    "build:client": "vite build --outDir ../dist/client",
    "build:server": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/server/index.js",
    "build": "npm run build:client && npm run build:server",
    "start": "cross-env NODE_ENV=production node dist/server/index.js",
    "check": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "node scripts/db-workflow.mjs check",
    "db:migrate:local": "node scripts/db-workflow.mjs migrate --url-env LOCAL_DATABASE_URL --seed",
    "db:migrate:replit": "node scripts/db-workflow.mjs migrate --url-env REPLIT_DATABASE_URL --seed",
    "db:sync:both": "node scripts/db-workflow.mjs sync --seed",
    "db:seed-translations": "tsx server/scripts/upsert-translations.cli.ts",
    "db:reset-media": "tsx server/scripts/reset-generated-media.cli.ts"
  },
